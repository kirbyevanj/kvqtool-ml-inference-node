FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir grpcio-tools pytest pytest-cov

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY proto/ proto/
RUN python -m grpc_tools.protoc \
    -Iproto \
    --python_out=proto \
    --grpc_python_out=proto \
    proto/inference.proto

COPY app/ app/
COPY tests/ tests/
COPY pytest.ini .

# Ensure proto dir is on PYTHONPATH for generated gRPC imports
ENV PYTHONPATH=/app/proto:/app

CMD ["python", "-m", "pytest", "tests/", "-v", "--cov=app", "--cov-report=term-missing"]
